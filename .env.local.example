# Gemini API key — used for embeddings (crawl + query) and chat completion.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase project URL — find it in your Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key — used server-side to read/write widget data.
# Find it in Supabase dashboard → Project Settings → API → service_role key.
# NEVER expose this in client code or commit it. Vercel: add to Project → Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL used when printing widget install snippets (no trailing slash).
# In production set to your deployed URL, e.g. https://webask.vercel.app
PUBLIC_BASE_URL=http://localhost:3000
